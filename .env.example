# Copy this to .env.local and fill in. Never commit .env.local.

# ============ Site URL ============
# Used for metadataBase — all relative URLs in metadata/OG tags are resolved
# against this. Set per environment:
#   - Staging on Netlify: NEXT_PUBLIC_SITE_URL=https://new.licoresources.com
#   - Production:         NEXT_PUBLIC_SITE_URL=https://www.licoresources.com
# If unset, falls back to https://www.licoresources.com.
NEXT_PUBLIC_SITE_URL=

# ============ Contact form (Resend) ============
# Get an API key at https://resend.com/api-keys
# Without this, the form still accepts submissions and logs them to the console.
RESEND_API_KEY=

# Where to send enquiries. Defaults to info@licoresources.com if unset.
CONTACT_TO_EMAIL=info@licoresources.com

# The from-address (must be a verified Resend sender or domain).
CONTACT_FROM_EMAIL=enquiries@licoresources.com

# ============ Analytics (optional) ============
# Plausible: just add the script in app/layout.tsx, no key needed.
# PostHog:
#   NEXT_PUBLIC_POSTHOG_KEY=
#   NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ============ Search Console verification ============
# Add when claiming ownership in Google Search Console.
# GOOGLE_SITE_VERIFICATION=
